# Environment variables for local development with Docker Compose
# Copy this file to .env and fill in your values.
# The .env file is ignored by Git.

# Backend Configuration
PORT=5000

# Backend -> Database Connection (for the backend service)
DB_HOST=db
DB_USER=root
DB_PASSWORD=secret
DB_NAME=sirqu_db_fix

# MySQL Container Configuration (for the db service)
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=sirqu_db_fix

# Application Secrets
JWT_SECRET=your-super-secret-jwt-key-that-is-long-and-random

# Frontend URL for CORS. For multiple origins, separate them with a comma.
CORS_ORIGIN=http://localhost:5173,http://localhost:5177